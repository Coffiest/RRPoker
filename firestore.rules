rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn()
        && storeId is string
        && exists(/databases/$(database)/documents/stores/$(storeId))
        && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == request.auth.uid;
    }

    function isStoreMember(storeId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.currentStoreId is string
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.currentStoreId == storeId
          )
          ||
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId is string
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == storeId
          )
        );
    }

    match /checkins/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {

      allow read: if isSignedIn();

      allow write: if isOwner(userId) || isSignedIn();

      match /storeBalances/{storeId} {
        allow read: if isOwner(userId) || isStoreMember(storeId);
        allow write: if isOwner(userId) || isStoreOwner(storeId);
      }

      match /tournamentHistory/{tournamentId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isSignedIn();
      }

      match /tickets/{ticketId} {
        allow read, write: if isOwner(userId);
      }

      match /storeStamp/{storeId} {
        allow read, write: if isOwner(userId) || isStoreOwner(storeId);
      }

      match /readNotices/{noticeId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /rrLeaderboard/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSignedIn();
    }

    match /stores/{storeId} {

      allow read: if isSignedIn();
      allow write: if isStoreOwner(storeId);

      match /tournaments/{tournamentId} {
        allow read: if isSignedIn();
        allow write: if isStoreOwner(storeId);

        match /players/{playerId} {
          allow read: if isSignedIn();
          allow write: if isStoreOwner(storeId);
        }

        match /entries/{userId} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId) || isStoreOwner(storeId);
        }

        match /results/{userId} {
          allow read: if isSignedIn();
          allow write: if isStoreOwner(storeId);
        }
      }

      match /blindPresets/{presetId} {
        allow read: if isSignedIn();
        allow write: if isStoreOwner(storeId);
      }

      match /publicRanking/{rankingId} {
        allow read: if isSignedIn();
        allow write: if isStoreOwner(storeId);
      }

      match /notices/{noticeId} {
        allow read: if isSignedIn();
        allow write: if isStoreOwner(storeId);
      }

      match /rakeEntries/{entryId} {
        allow read: if isSignedIn();
        allow write: if isStoreOwner(storeId);
      }
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    match /depositRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStoreOwner(request.resource.data.storeId);
    }

    match /withdrawRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStoreOwner(resource.data.storeId);
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn();
      allow write: if isStoreOwner(request.resource.data.storeId);
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isStoreOwner(request.resource.data.storeId);
    }

    match /friendRequests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /checkinRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStoreOwner(resource.data.storeId);
    }

    match /handHistories/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.creatorId;
    }
  }
}
